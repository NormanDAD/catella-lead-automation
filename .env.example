# ─── ADLEAD ────────────────────────────────────────────────
# Ta clé API Adlead (Paramètres > API Keys)
ADLEAD_API_KEY=

# Le secret webhook Adlead (reçu par email lors de la création du webhook)
ADLEAD_WEBHOOK_SECRET=

# Ton identifiant d'espace client Adlead (slug dans l'URL du CRM)
ADLEAD_TENANT=catella

# Base URL de l'API (ne pas changer sauf si Adlead change son endpoint)
ADLEAD_API_BASE=https://app.adlead.immo/api/v1

# ─── POWER AUTOMATE (envoi email depuis norman.dadon@catella.com) ──────────
# URL du trigger HTTP de ton flow Power Automate (voir guide-power-automate.docx)
# Format : https://prod-xx.francecentral.logic.azure.com:443/workflows/.../triggers/manual/paths/invoke?...&sig=...
POWER_AUTOMATE_URL=

# Clé partagée envoyée en header x-shared-secret (choisis une chaîne aléatoire 32+ caractères)
# Le flow vérifie cette valeur avant d'envoyer l'email
POWER_AUTOMATE_SECRET=

# Adresse email depuis laquelle envoyer (affichage — l'expéditeur réel est celui authentifié dans le flow)
SENDER_EMAIL=norman.dadon@catella.com

# ─── EMAIL TEMPLATE ───────────────────────────────────────
# Lien Outlook Booking affiché dans le mail ({lien_rdv})
BOOKING_URL=https://bookings.cloud.microsoft/book/Rendezvousdeprsentationprogramme@catella.fr/?ismsaljsauthenabled=true

# ─── TIMING ───────────────────────────────────────────────
# Délai d'attente avant re-vérification du statut du lead (en heures)
DELAY_HOURS=24

# Fréquence du scheduler (en ms) — détecte les leads dont l'attente est écoulée
SCHEDULER_INTERVAL_MS=300000

# ─── REPLY HANDLER (pilote — réponses prospect via Graph + Claude) ─────────
# Master switch. Tant que false, le poll inbox n'est JAMAIS lancé, même si
# ANTHROPIC_API_KEY est set et que Graph est authentifié.
REPLY_HANDLER_ENABLED=false

# Clé API Anthropic — utilisée pour classifier la réponse + rédiger le brouillon
ANTHROPIC_API_KEY=

# Modèle (default : claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Fréquence du poll inbox Graph (ms) — default 3 min
REPLY_POLL_INTERVAL_MS=180000

# Auth Microsoft Graph : via device code flow — voir AUTH_DEVICE_CODE.md.
# Le refresh_token est stocké automatiquement dans DATA_DIR/graph_token_cache.json
# après l'auth (pas d'env var à setter). Utilise le public client ID Azure CLI.

# ─── SERVEUR ──────────────────────────────────────────────
PORT=3000
